WITH
-- 1. Определяем дельту: данные, которые изменились или добавились в DWH с последней загрузки
dwh_delta AS (
    SELECT
        dcust.customer_id AS customer_id,
        dcust.customer_name AS customer_name,
        dcust.customer_address AS customer_address,
        dcust.customer_birthday AS customer_birthday,
        dcust.customer_email AS customer_email,
        fo.order_id AS order_id,
        fo.craftsman_id AS craftsman_id,
        dp.product_id AS product_id,
        dp.product_price AS product_price,
        dp.product_type AS product_type,
        fo.order_completion_date - fo.order_created_date AS diff_order_date,
        fo.order_status AS order_status,
        TO_CHAR(fo.order_created_date, 'yyyy-mm') AS report_period,
        crd.customer_id AS exist_customer_id,
        dcust.load_dttm AS customers_load_dttm,
        dc.load_dttm AS craftsman_load_dttm,
        dp.load_dttm AS products_load_dttm,
        fo.load_dttm AS orders_load_dttm
    FROM dwh.f_order fo
    INNER JOIN dwh.d_customer dcust ON fo.customer_id = dcust.customer_id
    INNER JOIN dwh.d_craftsman dc ON fo.craftsman_id = dc.craftsman_id
    INNER JOIN dwh.d_product dp ON fo.product_id = dp.product_id
    LEFT JOIN dwh.customer_report_datamart crd ON dcust.customer_id = crd.customer_id AND TO_CHAR(fo.order_created_date, 'yyyy-mm') = crd.report_period
    WHERE (fo.load_dttm > (SELECT COALESCE(MAX(load_dttm),'1900-01-01') FROM dwh.load_dates_customer_report_datamart)) OR
          (dcust.load_dttm > (SELECT COALESCE(MAX(load_dttm),'1900-01-01') FROM dwh.load_dates_customer_report_datamart)) OR
          (dc.load_dttm > (SELECT COALESCE(MAX(load_dttm),'1900-01-01') FROM dwh.load_dates_customer_report_datamart)) OR
          (dp.load_dttm > (SELECT COALESCE(MAX(load_dttm),'1900-01-01') FROM dwh.load_dates_customer_report_datamart))
),

-- 2. Список заказчиков, по которым данные в витрине нужно обновить (уже есть в витрине)
dwh_update_delta AS (
    SELECT DISTINCT dd.exist_customer_id AS customer_id
    FROM dwh_delta dd
    WHERE dd.exist_customer_id IS NOT NULL
),

-- 3. Расчет показателей (универсальный блок для вставки и обновления)
calculated_data AS (
    SELECT 
        T2.*,
        T3.top_product_category,
        T3.top_craftsman_id
    FROM (
        -- Основные агрегаты
        SELECT
            T1.customer_id, T1.customer_name, T1.customer_address, T1.customer_birthday, T1.customer_email, T1.report_period,
            SUM(T1.product_price) AS customer_money,
            SUM(T1.product_price) * 0.1 AS platform_money,
            COUNT(order_id) AS count_order,
            AVG(T1.product_price) AS avg_price_order,
            PERCENTILE_CONT(0.5) WITHIN GROUP(ORDER BY diff_order_date) AS median_time_order_completed,
            SUM(CASE WHEN T1.order_status = 'created' THEN 1 ELSE 0 END) AS count_order_created,
            SUM(CASE WHEN T1.order_status = 'in progress' THEN 1 ELSE 0 END) AS count_order_in_progress,
            SUM(CASE WHEN T1.order_status = 'delivery' THEN 1 ELSE 0 END) AS count_order_delivery,
            SUM(CASE WHEN T1.order_status = 'done' THEN 1 ELSE 0 END) AS count_order_done,
            SUM(CASE WHEN T1.order_status != 'done' THEN 1 ELSE 0 END) AS count_order_not_done
        FROM dwh_delta T1
        GROUP BY T1.customer_id, T1.customer_name, T1.customer_address, T1.customer_birthday, T1.customer_email, T1.report_period
    ) T2
    INNER JOIN (
        -- Самый популярный товар и мастер (используем RANK для выбора одного из многих при равенстве)
        SELECT 
            customer_id, report_period,
            product_type AS top_product_category,
            craftsman_id AS top_craftsman_id
        FROM (
            SELECT 
                customer_id, report_period, product_type, craftsman_id,
                RANK() OVER(PARTITION BY customer_id, report_period ORDER BY COUNT(product_id) DESC, COUNT(craftsman_id) DESC) as rnk
            FROM dwh_delta
            GROUP BY customer_id, report_period, product_type, craftsman_id
        ) r WHERE rnk = 1
    ) T3 ON T2.customer_id = T3.customer_id AND T2.report_period = T3.report_period
),

-- 4. Вставка новых данных
insert_step AS (
    INSERT INTO dwh.customer_report_datamart (
        customer_id, customer_name, customer_address, customer_birthday, customer_email,
        customer_money, platform_money, count_order, avg_price_order, median_time_order_completed,
        top_product_category, top_craftsman_id, count_order_created, count_order_in_progress,
        count_order_delivery, count_order_done, count_order_not_done, report_period
    )
    SELECT 
        customer_id, customer_name, customer_address, customer_birthday, customer_email,
        customer_money, platform_money, count_order, avg_price_order, median_time_order_completed,
        top_product_category, top_craftsman_id, count_order_created, count_order_in_progress,
        count_order_delivery, count_order_done, count_order_not_done, report_period
    FROM calculated_data
    WHERE customer_id NOT IN (SELECT customer_id FROM dwh_update_delta)
),

-- 5. Обновление существующих записей
update_step AS (
    UPDATE dwh.customer_report_datamart cd
    SET
        customer_name = ud.customer_name,
        customer_address = ud.customer_address,
        customer_birthday = ud.customer_birthday,
        customer_email = ud.customer_email,
        customer_money = ud.customer_money,
        platform_money = ud.platform_money,
        count_order = ud.count_order,
        avg_price_order = ud.avg_price_order,
        median_time_order_completed = ud.median_time_order_completed,
        top_product_category = ud.top_product_category,
        top_craftsman_id = ud.top_craftsman_id,
        count_order_created = ud.count_order_created,
        count_order_in_progress = ud.count_order_in_progress,
        count_order_delivery = ud.count_order_delivery,
        count_order_done = ud.count_order_done,
        count_order_not_done = ud.count_order_not_done
    FROM calculated_data ud
    WHERE cd.customer_id = ud.customer_id AND cd.report_period = ud.report_period
    AND cd.customer_id IN (SELECT customer_id FROM dwh_update_delta)
),

-- 6. Фиксация даты загрузки
log_step AS (
    INSERT INTO dwh.load_dates_customer_report_datamart (load_dttm)
    SELECT GREATEST(
        MAX(customers_load_dttm), 
        MAX(craftsman_load_dttm), 
        MAX(products_load_dttm), 
        MAX(orders_load_dttm)
    )
    FROM dwh_delta
)
SELECT 'Incremental update completed' AS status;
